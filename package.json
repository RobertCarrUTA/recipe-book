{
  "name": "recipe-book",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:recipes": "node scripts/build-recipes.mjs",
    "check:recipes": "node scripts/build-recipes.mjs --check",
    "update:normalization-snapshot": "node scripts/update-normalization-catalog-snapshot.mjs",
    "set-asset-version": "node scripts/set-asset-version.mjs",
    "check:syntax": "node scripts/check-syntax.mjs",
    "report:data-quality": "node scripts/report-data-quality.mjs",
    "smoke:browser": "node scripts/smoke-browser.mjs",
    "test": "node scripts/run-tests.mjs",
    "verify:app": "node scripts/verify-app.mjs",
    "verify": "npm run check:syntax && npm run check:recipes && npm run test && npm run verify:app",
    "verify:full": "npm run verify && npm run smoke:browser"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
